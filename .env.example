# Copy to .env (gitignored) and fill in your own keys. NEVER commit the real .env.
# The plugins read these at runtime; the keys live here, not inside any plugin.

# Financial Modeling Prep (premium) — movers, prices, VIX, fundamentals
FMP_API_KEY=

# IBKR is a LOCAL gateway, not a key: run TWS or IB Gateway on your machine and
# the vol-pulse IBKR adapter connects to 127.0.0.1 (paper 7497 / live 7496).
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
